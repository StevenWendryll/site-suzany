---
// Caminho: src/pages/servicos/[slug].astro
import LayoutBase from "../../layouts/LayoutBase.astro";
import { client } from "../../lib/sanityClient";
import { toHTML } from "@portabletext/to-html";

type ServicoSlug = {
    slug: { current: string };
};

export async function getStaticPaths() {
    const query = `*[_type == "servico" && defined(slug.current)]{ slug }`;
    const servicos = await client.fetch<ServicoSlug[]>(query);
    return servicos.map((s) => ({
        params: { slug: s.slug.current },
    }));
}

const { slug } = Astro.params;

type ServicoCompleto = {
    titulo: string;
    descricaoCompleta: any;
};

const queryCompleta = `*[_type == "servico" && slug.current == $slug][0]{ titulo, descricaoCompleta }`;
const servico = await client.fetch<ServicoCompleto>(queryCompleta, { slug });

const conteudoHtml = toHTML(servico.descricaoCompleta);
---

<LayoutBase title={servico.titulo}>

	<!-- Breadcrumb -->
	<nav class="breadcrumb" aria-label="Caminho de navegação">
		<a href="/">Início</a>
		<span aria-hidden="true">›</span>
		<a href="/servicos">Serviços</a>
		<span aria-hidden="true">›</span>
		<span aria-current="page">{servico.titulo}</span>
	</nav>

	<div class="servico-layout">
		<!-- Conteúdo principal -->
		<article class="servico-artigo">
			<header class="servico-header">
				<span class="eyebrow">Tratamento</span>
				<h1 class="servico-titulo">{servico.titulo}</h1>
			</header>

			<div class="servico-prose" set:html={conteudoHtml} />
		</article>

		<!-- Sidebar -->
		<aside class="servico-sidebar" aria-label="Informações e contato">
			<div class="sidebar-card">
				<h2 class="sidebar-titulo">Agende sua consulta</h2>
				<p class="sidebar-texto">
					Quer saber mais sobre este tratamento ou agendar uma avaliação?
					Entre em contato:
				</p>
				<div class="sidebar-acoes">
					<a href="/contato" class="btn-primary">Agendar Avaliação</a>
					<a
						href="https://wa.me/5528999249583?text=Olá!%20Gostaria%20de%20saber%20mais%20sobre%20o%20tratamento:%20{servico.titulo}"
						target="_blank"
						rel="noopener noreferrer"
						class="btn-wa"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.535 5.858L.057 23.571a.75.75 0 0 0 .921.921l5.713-1.478A11.947 11.947 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.706 9.706 0 0 1-4.95-1.357l-.355-.21-3.681.951.977-3.566-.232-.368A9.706 9.706 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/></svg>
						WhatsApp
					</a>
				</div>
			</div>

			<div class="sidebar-card sidebar-info">
				<h3 class="sidebar-info-titulo">Informações</h3>
				<ul class="sidebar-info-lista">
					<li>
						<span class="info-icon" aria-hidden="true">📍</span>
						Anchieta – ES
					</li>
					<li>
						<span class="info-icon" aria-hidden="true">🕐</span>
						Seg – Sex · 8h às 18h
					</li>
					<li>
						<span class="info-icon" aria-hidden="true">📋</span>
						CREFITO: 449069-F
					</li>
				</ul>
			</div>

			<a href="/servicos" class="sidebar-back">
				← Ver todos os tratamentos
			</a>
		</aside>
	</div>
</LayoutBase>

<style>
	/* Breadcrumb */
	.breadcrumb {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.4rem;
		font-size: 0.82rem;
		color: var(--texto-muted);
		margin-bottom: 2rem;
	}

	.breadcrumb a {
		text-decoration: none;
		transition: color var(--dur) var(--ease);
	}

	.breadcrumb a:hover { color: var(--verde); }

	.breadcrumb span[aria-current="page"] {
		color: var(--texto);
		font-weight: 500;
	}

	/* Layout */
	.servico-layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		align-items: start;
	}

	@media (min-width: 900px) {
		.servico-layout { grid-template-columns: 1fr 320px; gap: 2.5rem; }
	}

	/* Artigo */
	.servico-artigo {
		background: var(--branco);
		border: 1px solid var(--borda);
		border-radius: var(--raio-xl);
		padding: clamp(2rem, 5vw, 3rem);
		box-shadow: var(--sombra-sm);
	}

	.servico-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--borda); }

	.eyebrow {
		display: inline-block;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--verde);
		margin-bottom: 0.6rem;
	}

	.servico-titulo {
		font-family: var(--fonte-serif);
		font-size: clamp(1.8rem, 4vw, 2.6rem);
		font-weight: 700;
		color: var(--texto);
		letter-spacing: -0.02em;
		line-height: 1.12;
	}

	/* Prose - conteúdo do CMS */
	.servico-prose {
		font-size: 1rem;
		color: var(--texto-muted);
		line-height: 1.8;
	}

	.servico-prose :global(h2) {
		font-family: var(--fonte-serif);
		font-size: 1.4rem;
		font-weight: 700;
		color: var(--texto);
		margin: 2rem 0 0.75rem;
		letter-spacing: -0.01em;
	}

	.servico-prose :global(h3) {
		font-family: var(--fonte-serif);
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--texto);
		margin: 1.5rem 0 0.5rem;
	}

	.servico-prose :global(p) {
		margin-bottom: 1rem;
	}

	.servico-prose :global(ul),
	.servico-prose :global(ol) {
		margin: 1rem 0;
		padding-left: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.servico-prose :global(ul li) {
		position: relative;
		padding-left: 1.5rem;
	}

	.servico-prose :global(ul li)::before {
		content: '';
		position: absolute;
		left: 0;
		top: 11px;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--verde-mid);
	}

	.servico-prose :global(ol) {
		counter-reset: item;
	}

	.servico-prose :global(ol li) {
		position: relative;
		padding-left: 2rem;
		counter-increment: item;
	}

	.servico-prose :global(ol li)::before {
		content: counter(item);
		position: absolute;
		left: 0;
		top: 1px;
		width: 22px;
		height: 22px;
		background: var(--verde-suave);
		color: var(--verde);
		border-radius: 50%;
		font-size: 0.78rem;
		font-weight: 700;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.servico-prose :global(strong) {
		font-weight: 600;
		color: var(--texto);
	}

	.servico-prose :global(a) {
		color: var(--verde);
		text-decoration: underline;
	}

	.servico-prose :global(blockquote) {
		border-left: 3px solid var(--verde-mid);
		margin: 1.5rem 0;
		padding: 1rem 1.5rem;
		background: var(--verde-suave);
		border-radius: 0 var(--raio) var(--raio) 0;
		font-style: italic;
	}

	/* Sidebar */
	.servico-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.sidebar-card {
		background: var(--branco);
		border: 1px solid var(--borda);
		border-radius: var(--raio-lg);
		padding: 1.75rem;
		box-shadow: var(--sombra-sm);
	}

	.sidebar-titulo {
		font-family: var(--fonte-serif);
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--texto);
		margin-bottom: 0.75rem;
	}

	.sidebar-texto {
		font-size: 0.9rem;
		color: var(--texto-muted);
		line-height: 1.65;
		margin-bottom: 1.25rem;
	}

	.sidebar-acoes {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.btn-wa {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		background: #25d366;
		color: #fff;
		font-size: 0.88rem;
		font-weight: 600;
		padding: 11px 20px;
		border-radius: 100px;
		text-decoration: none;
		transition: background var(--dur) var(--ease), transform var(--dur) var(--ease);
		text-align: center;
	}

	.btn-wa:hover {
		background: #20ba5a;
		transform: translateY(-1px);
	}

	/* Info card */
	.sidebar-info { background: var(--verde-suave); border-color: var(--verde-mid); }

	.sidebar-info-titulo {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--verde);
		margin-bottom: 1rem;
	}

	.sidebar-info-lista {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.sidebar-info-lista li {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		font-size: 0.9rem;
		color: var(--texto);
		font-weight: 500;
	}

	.info-icon { font-size: 1rem; }

	/* Voltar */
	.sidebar-back {
		font-size: 0.88rem;
		font-weight: 500;
		color: var(--texto-muted);
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		padding: 10px 14px;
		border-radius: var(--raio);
		transition: color var(--dur) var(--ease), background var(--dur) var(--ease);
	}

	.sidebar-back:hover {
		color: var(--verde);
		background: var(--verde-suave);
	}
</style>
