---
// Caminho: src/pages/servicos.astro
import LayoutBase from "../layouts/LayoutBase.astro";
import { client } from "../lib/sanityClient";

type Servico = {
  titulo: string;
  resumo: string;
  slug: { current: string };
};
// Filtro para garantir que o slug exista
const query = `*[_type == "servico" && defined(slug.current)]{ titulo, resumo, slug }`;
const servicos = await client.fetch<Servico[]>(query);
---

<LayoutBase title="Nossos Tratamentos">
  <div
    class="relative h-48 md:h-56 rounded-lg overflow-hidden bg-cover bg-center mb-8"
    style="background-image: url('/images/servico-background.jpg');"
  >
    <div class="absolute inset-0 bg-black opacity-40"></div>
    <div class="relative z-10 flex items-center justify-center text-center h-full">
      <h1 class="text-4xl font-bold text-white">Nossos Tratamentos</h1>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {
      servicos.map((servico) => (
        <div class="bg-white p-8 rounded-lg shadow-lg flex flex-col">
          <h3 class="text-xl font-bold text-blue-800 mb-3">{servico.titulo}</h3>
          <p class="text-gray-600 mb-6 flex-grow">{servico.resumo}</p>
          <a
            href={`/servicos/${servico.slug.current}/`}
            class="bg-blue-700 text-white font-bold py-2 px-5 rounded-lg hover:bg-blue-800 text-center"
          >
            Saiba Mais
          </a>
        </div>
      ))
    }
  </div>
</LayoutBase>
