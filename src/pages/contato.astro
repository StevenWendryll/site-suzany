---
// Caminho: src/pages/contato.astro
import LayoutBase from "../layouts/LayoutBase.astro";
---

<LayoutBase title="Contato e Agendamento">

	<div class="page-hero">
		<div class="page-hero-bg">
			<img src="/images/hero-background.jpg" alt="" loading="lazy" />
		</div>
		<div class="page-hero-content">
			<span class="page-hero-label">Estamos aqui</span>
			<h1 class="page-hero-title">Entre em Contato</h1>
		</div>
	</div>

	<div class="contato-grid">

		<!-- ── Formulário ── -->
		<div class="form-card">
			<div class="form-header">
				<span class="eyebrow">Agendamento</span>
				<h2 class="form-titulo">Agende sua avaliação</h2>
				<p class="form-sub">Preencha o formulário e entraremos em contato em breve.</p>
			</div>

			<form
				action="https://formspree.io/f/xqagvdnl"
				method="POST"
				class="form"
				novalidate
			>
				<input type="hidden" name="_next" value="/obrigado" />
				<input type="hidden" name="_subject" value="Novo Paciente (Contato do Site)" />
				<input type="hidden" name="_language" value="pt" />

				<div class="field-row">
					<div class="field">
						<label class="field-label" for="name">Nome completo</label>
						<input
							class="field-input"
							id="name"
							type="text"
							name="name"
							placeholder="Seu nome"
							required
							autocomplete="name"
						/>
					</div>
				</div>

				<div class="field-row two-cols">
					<div class="field">
						<label class="field-label" for="email">E-mail</label>
						<input
							class="field-input"
							id="email"
							type="email"
							name="email"
							placeholder="seu@email.com"
							required
							autocomplete="email"
						/>
					</div>
					<div class="field">
						<label class="field-label" for="phone">Telefone / WhatsApp</label>
						<input
							class="field-input"
							id="phone"
							type="tel"
							name="phone"
							placeholder="(28) 99999-9999"
							autocomplete="tel"
						/>
					</div>
				</div>

				<div class="field">
					<label class="field-label" for="message">Mensagem</label>
					<textarea
						class="field-input field-textarea"
						id="message"
						name="message"
						placeholder="Descreva brevemente sua queixa ou dúvida..."
						required
						autocomplete="off"
					></textarea>
				</div>

				<div class="field-check">
					<label class="check-label">
						<input type="checkbox" class="check-input" required />
						<span class="check-box" aria-hidden="true"></span>
						<span class="check-text">
							Li e concordo com a
							<a href="/politica-de-privacidade">Política de Privacidade</a>.
						</span>
					</label>
				</div>

				<button type="submit" class="btn-submit">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
					Enviar Mensagem
				</button>
			</form>
		</div>

		<!-- ── Sidebar de informações ── -->
		<aside class="info-col" aria-label="Informações de contato">

			<!-- Contatos -->
			<div class="info-card">
				<h3 class="info-titulo">Informações</h3>
				<ul class="info-lista">
					<li>
						<div class="info-icon" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 0 6.08 6.08l.95-.95a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
						</div>
						<div>
							<span class="info-label">Telefone / WhatsApp</span>
							<a href="tel:+5528999249583" class="info-value">(28) 99924-9583</a>
						</div>
					</li>
					<li>
						<div class="info-icon" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
						</div>
						<div>
							<span class="info-label">E-mail</span>
							<a href="mailto:suzanyflorencini@gmail.com" class="info-value">suzanyflorencini@gmail.com</a>
						</div>
					</li>
					<li>
						<div class="info-icon" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
						</div>
						<div>
							<span class="info-label">Horário de atendimento</span>
							<span class="info-value">Seg – Sex · 8h às 18h</span>
						</div>
					</li>
					<li>
						<div class="info-icon" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
						</div>
						<div>
							<span class="info-label">Endereço</span>
							<span class="info-value">Anchieta – ES</span>
						</div>
					</li>
				</ul>
			</div>

			<!-- WhatsApp direto -->
			<a
				href="https://wa.me/5528999249583?text=Olá!%20Gostaria%20de%20agendar%20uma%20avaliação."
				target="_blank"
				rel="noopener noreferrer"
				class="whatsapp-card"
				aria-label="Falar pelo WhatsApp"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.535 5.858L.057 23.571a.75.75 0 0 0 .921.921l5.713-1.478A11.947 11.947 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.706 9.706 0 0 1-4.95-1.357l-.355-.21-3.681.951.977-3.566-.232-.368A9.706 9.706 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/></svg>
				<span>Falar pelo WhatsApp</span>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
			</a>

			<!-- Mapa -->
			<div class="mapa-wrap">
				<iframe
					src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d59676.38757326853!2d-40.68094498873008!3d-20.800420032600694!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xb8fd6039a98b97%3A0x373ef608b9c655a0!2sAnchieta%2C%20ES%2C%2029230-000!5e0!3m2!1spt-BR!2sbr!4v1762222799507!5m2!1spt-BR!2sbr"
					width="100%"
					height="280"
					style="border:0;"
					allowfullscreen=""
					loading="lazy"
					title="Localização – Anchieta, ES"
				></iframe>
			</div>
		</aside>
	</div>
</LayoutBase>

<style>
	.contato-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		align-items: start;
	}

	@media (min-width: 900px) {
		.contato-grid { grid-template-columns: 1fr 380px; gap: 2.5rem; }
	}

	/* ── Formulário ── */
	.form-card {
		background: var(--branco);
		border: 1px solid var(--borda);
		border-radius: var(--raio-xl);
		padding: clamp(1.75rem, 4vw, 2.75rem);
		box-shadow: var(--sombra-sm);
	}

	.form-header { margin-bottom: 2rem; }

	.eyebrow {
		display: inline-block;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--verde);
		margin-bottom: 0.5rem;
	}

	.form-titulo {
		font-family: var(--fonte-serif);
		font-size: clamp(1.4rem, 3vw, 1.9rem);
		font-weight: 700;
		color: var(--texto);
		letter-spacing: -0.02em;
		margin-bottom: 0.4rem;
	}

	.form-sub {
		font-size: 0.92rem;
		color: var(--texto-muted);
	}

	.form {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.field-row { display: contents; }

	.two-cols {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.25rem;
	}

	@media (max-width: 560px) {
		.two-cols { grid-template-columns: 1fr; }
	}

	.field {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.field-label {
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--texto);
		letter-spacing: 0.01em;
	}

	.field-input {
		font-family: var(--fonte-sans);
		font-size: 0.93rem;
		color: var(--texto);
		background: var(--creme);
		border: 1.5px solid var(--borda);
		border-radius: var(--raio);
		padding: 11px 14px;
		width: 100%;
		transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease), background var(--dur) var(--ease);
		outline: none;
		-webkit-appearance: none;
	}

	.field-input::placeholder { color: #b0aaa0; }

	.field-input:focus {
		border-color: var(--verde);
		background: var(--branco);
		box-shadow: 0 0 0 3px rgba(45, 122, 95, 0.12);
	}

	.field-textarea {
		resize: vertical;
		min-height: 120px;
	}

	/* Checkbox customizado */
	.field-check { margin-top: 0.25rem; }

	.check-label {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		cursor: pointer;
	}

	.check-input {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
	}

	.check-box {
		width: 18px;
		height: 18px;
		min-width: 18px;
		border: 1.5px solid var(--borda);
		border-radius: 5px;
		background: var(--creme);
		display: flex;
		align-items: center;
		justify-content: center;
		margin-top: 1px;
		transition: border-color var(--dur) var(--ease), background var(--dur) var(--ease);
	}

	.check-input:checked ~ .check-box {
		background: var(--verde);
		border-color: var(--verde);
	}

	.check-input:checked ~ .check-box::after {
		content: '';
		display: block;
		width: 5px;
		height: 9px;
		border: 2px solid #fff;
		border-top: none;
		border-left: none;
		transform: rotate(45deg) translateY(-1px);
	}

	.check-input:focus-visible ~ .check-box {
		box-shadow: 0 0 0 3px rgba(45, 122, 95, 0.18);
	}

	.check-text {
		font-size: 0.85rem;
		color: var(--texto-muted);
		line-height: 1.5;
	}

	.check-text a {
		color: var(--verde);
		text-decoration: underline;
	}

	.btn-submit {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		width: 100%;
		background: var(--verde);
		color: var(--branco);
		font-family: var(--fonte-sans);
		font-size: 0.95rem;
		font-weight: 600;
		padding: 14px 24px;
		border: none;
		border-radius: 100px;
		cursor: pointer;
		transition: background var(--dur) var(--ease), transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
		box-shadow: 0 2px 12px rgba(45, 122, 95, 0.35);
	}

	.btn-submit:hover {
		background: var(--verde-claro);
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(45, 122, 95, 0.45);
	}

	.btn-submit:active { transform: translateY(0); }

	/* ── Sidebar ── */
	.info-col {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.info-card {
		background: var(--branco);
		border: 1px solid var(--borda);
		border-radius: var(--raio-lg);
		padding: 1.75rem;
		box-shadow: var(--sombra-sm);
	}

	.info-titulo {
		font-family: var(--fonte-serif);
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--texto);
		margin-bottom: 1.25rem;
	}

	.info-lista {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
	}

	.info-lista li {
		display: flex;
		align-items: flex-start;
		gap: 0.875rem;
	}

	.info-icon {
		width: 36px;
		height: 36px;
		min-width: 36px;
		background: var(--verde-suave);
		border-radius: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--verde);
	}

	.info-label {
		display: block;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--texto-muted);
		margin-bottom: 2px;
	}

	.info-value {
		display: block;
		font-size: 0.92rem;
		font-weight: 500;
		color: var(--texto);
		text-decoration: none;
		transition: color var(--dur) var(--ease);
	}

	a.info-value:hover { color: var(--verde); }

	/* WhatsApp card */
	.whatsapp-card {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		background: #25d366;
		color: #fff;
		text-decoration: none;
		border-radius: var(--raio-lg);
		padding: 1.1rem 1.5rem;
		font-size: 0.95rem;
		font-weight: 600;
		transition: background var(--dur) var(--ease), transform var(--dur) var(--ease);
		box-shadow: 0 2px 12px rgba(37, 211, 102, 0.35);
	}

	.whatsapp-card span { flex: 1; }

	.whatsapp-card:hover {
		background: #20ba5a;
		transform: translateY(-2px);
	}

	/* Mapa */
	.mapa-wrap {
		border-radius: var(--raio-lg);
		overflow: hidden;
		border: 1px solid var(--borda);
		box-shadow: var(--sombra-sm);
	}

	.mapa-wrap iframe { display: block; }
</style>
