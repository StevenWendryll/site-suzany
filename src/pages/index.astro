---
// Caminho: src/pages/index.astro
import LayoutBase from "../layouts/LayoutBase.astro";
import { client } from "../lib/sanityClient";

type Servico = {
	titulo: string;
	resumo: string;
	icone?: string;
};

const query = `*[_type == "servico"]{ titulo, resumo, icone }`;
const servicos = await client.fetch<Servico[]>(query);

const iconePadrao = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M12 2a10 10 0 0 1 10 10"/></svg>`;
---

<LayoutBase title="Início – Alívio da dor e recuperação">

	<!-- ═══════════════ HERO ═══════════════ -->
	<section class="hero" aria-label="Apresentação">
		<div class="hero-bg" aria-hidden="true">
			<img
				src="/images/hero-background.jpg"
				alt=""
				class="hero-img"
				loading="eager"
				fetchpriority="high"
			/>
			<div class="hero-overlay"></div>
		</div>

		<div class="hero-content">
			<span class="hero-pill">Fisioterapia Especializada · Piúma – ES</span>

			<h1 class="hero-title">
				Alívio da Dor<br />
				<em>e Recuperação</em>
			</h1>

			<p class="hero-sub">
				Sua especialista em fisioterapia ortopédica e saúde da mulher.<br class="br-md" />
				Cuidado humanizado, do diagnóstico à sua plena recuperação.
			</p>

			<div class="hero-actions">
				<a href="/contato" class="btn-hero-primary">
					<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
					Agendar Avaliação
				</a>
				<a href="/sobre" class="btn-hero-ghost">Conhecer a clínica →</a>
			</div>

			<!-- Estatísticas -->
			<div class="hero-stats" aria-label="Números da clínica">
				<div class="stat">
					<strong>+500</strong>
					<span>Pacientes atendidos</span>
				</div>
				<div class="stat-sep" aria-hidden="true"></div>
				<div class="stat">
					<strong>10+</strong>
					<span>Anos de experiência</span>
				</div>
				<div class="stat-sep" aria-hidden="true"></div>
				<div class="stat">
					<strong>CREFITO</strong>
					<span>Registrada</span>
				</div>
			</div>
		</div>

		<div class="scroll-hint" aria-hidden="true">
			<span>Nossos tratamentos</span>
			<div class="scroll-chevron"></div>
		</div>
	</section>

	<!-- ═══════════════ SERVIÇOS ═══════════════ -->
	<section class="servicos" aria-labelledby="servicos-h2">
		<header class="section-header">
			<span class="section-eyebrow">O que oferecemos</span>
			<h2 id="servicos-h2" class="section-title">Nossos Tratamentos</h2>
			<p class="section-desc">
				Abordagem individualizada para cada paciente, com técnicas baseadas em evidências científicas.
			</p>
		</header>

		{servicos.length > 0 ? (
			<ul class="cards-grid" role="list">
				{servicos.map((s, i) => (
					<li class="card" style={`--i:${i}`}>
						<div class="card-icon" aria-hidden="true">
							{s.icone
								? <img src={s.icone} alt="" width="24" height="24" />
								: <Fragment set:html={iconePadrao} />
							}
						</div>
						<h3 class="card-title">{s.titulo}</h3>
						<p class="card-desc">{s.resumo}</p>
						<a
							href={`/servicos/${s.titulo.toLowerCase().replace(/\s+/g, '-')}`}
							class="card-link"
							aria-label={`Saiba mais sobre ${s.titulo}`}
						>
							Saiba mais <span aria-hidden="true">→</span>
						</a>
					</li>
				))}
			</ul>
		) : (
			<p class="empty-msg">Nenhum tratamento cadastrado ainda.</p>
		)}
	</section>

	<!-- ═══════════════ CTA ═══════════════ -->
	<section class="cta-wrap" aria-labelledby="cta-h2">
		<div class="cta-box">
			<div class="cta-deco" aria-hidden="true"></div>
			<h2 id="cta-h2" class="cta-title">Pronta para começar sua recuperação?</h2>
			<p class="cta-sub">Entre em contato e agende sua avaliação inicial sem compromisso.</p>
			<a href="/contato" class="btn-primary btn-lg">Agendar agora</a>
		</div>
	</section>

</LayoutBase>

<style>
	/* ── HERO ── */
	.hero {
		position: relative;
		min-height: min(92vh, 700px);
		display: flex;
		flex-direction: column;
		justify-content: center;
		border-radius: var(--raio-xl);
		overflow: hidden;
		isolation: isolate;
		margin-bottom: 5rem;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: -1;
	}

	.hero-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 30%;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			130deg,
			rgba(10, 25, 47, 0.88) 0%,
			rgba(10, 25, 47, 0.65) 55%,
			rgba(10, 25, 47, 0.35) 100%
		);
	}

	.hero-content {
		position: relative;
		padding: clamp(2.5rem, 7vw, 5rem) clamp(1.5rem, 6vw, 5rem);
		max-width: 640px;
	}

	.hero-pill {
		display: inline-block;
		background: rgba(255,255,255,0.10);
		backdrop-filter: blur(8px);
		border: 1px solid rgba(255,255,255,0.18);
		color: rgba(255,255,255,0.82);
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 6px 14px;
		border-radius: 100px;
		margin-bottom: 1.5rem;
	}

	.hero-title {
		font-family: var(--fonte-serif);
		font-size: clamp(2.4rem, 6vw, 4rem);
		font-weight: 700;
		color: #fff;
		line-height: 1.08;
		letter-spacing: -0.03em;
		margin-bottom: 1.25rem;
	}

	.hero-title em {
		font-style: italic;
		color: #86efb5;
	}

	.hero-sub {
		font-size: clamp(1rem, 2.2vw, 1.1rem);
		color: rgba(255,255,255,0.72);
		line-height: 1.7;
		margin-bottom: 2.25rem;
	}

	.hero-actions {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 1.25rem;
		margin-bottom: 3rem;
	}

	.btn-hero-primary {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		background: var(--verde);
		color: #fff;
		font-size: 0.93rem;
		font-weight: 600;
		padding: 14px 26px;
		border-radius: 100px;
		text-decoration: none;
		transition: background var(--dur) var(--ease), transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
		box-shadow: 0 3px 14px rgba(45, 122, 95, 0.5);
	}

	.btn-hero-primary:hover {
		background: var(--verde-claro);
		transform: translateY(-2px);
		box-shadow: 0 6px 22px rgba(45, 122, 95, 0.55);
	}

	.btn-hero-ghost {
		display: inline-flex;
		align-items: center;
		color: rgba(255,255,255,0.78);
		font-size: 0.93rem;
		font-weight: 500;
		text-decoration: none;
		transition: color var(--dur) var(--ease);
	}

	.btn-hero-ghost:hover { color: #fff; }

	/* Stats */
	.hero-stats {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 1.5rem;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 3px;
	}

	.stat strong {
		font-family: var(--fonte-serif);
		font-size: 1.4rem;
		font-weight: 700;
		color: #fff;
		line-height: 1;
		letter-spacing: -0.02em;
	}

	.stat span {
		font-size: 0.72rem;
		color: rgba(255,255,255,0.50);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.stat-sep {
		width: 1px;
		height: 36px;
		background: rgba(255,255,255,0.15);
		flex-shrink: 0;
	}

	/* Scroll hint */
	.scroll-hint {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
		color: rgba(255,255,255,0.42);
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		pointer-events: none;
	}

	.scroll-chevron {
		width: 14px;
		height: 14px;
		border-right: 1.5px solid rgba(255,255,255,0.35);
		border-bottom: 1.5px solid rgba(255,255,255,0.35);
		transform: rotate(45deg);
		animation: bounceDown 1.8s ease-in-out infinite;
	}

	@keyframes bounceDown {
		0%, 100% { opacity: 0.3; transform: rotate(45deg) translateY(0); }
		50% { opacity: 0.8; transform: rotate(45deg) translateY(5px); }
	}

	/* ── SERVIÇOS ── */
	.servicos { margin-bottom: 5rem; }

	.section-header {
		text-align: center;
		margin-bottom: 3rem;
		max-width: 560px;
		margin-left: auto;
		margin-right: auto;
	}

	.section-eyebrow {
		display: inline-block;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--verde);
		margin-bottom: 0.75rem;
	}

	.section-title {
		font-family: var(--fonte-serif);
		font-size: clamp(1.8rem, 4vw, 2.6rem);
		font-weight: 700;
		color: var(--texto);
		letter-spacing: -0.02em;
		margin-bottom: 0.75rem;
		line-height: 1.15;
	}

	.section-desc {
		font-size: 1rem;
		color: var(--texto-muted);
		line-height: 1.7;
	}

	.cards-grid {
		list-style: none;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.5rem;
	}

	.card {
		background: var(--branco);
		border: 1px solid var(--borda);
		border-radius: var(--raio-lg);
		padding: 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		box-shadow: var(--sombra-sm);
		transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease);
		opacity: 0;
		animation: cardIn 0.45s var(--ease) forwards;
		animation-delay: calc(var(--i, 0) * 80ms + 100ms);
	}

	@keyframes cardIn {
		from { opacity: 0; transform: translateY(18px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	.card:hover {
		transform: translateY(-5px);
		box-shadow: var(--sombra-md);
		border-color: var(--verde-mid);
	}

	.card-icon {
		width: 46px;
		height: 46px;
		background: var(--verde-suave);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--verde);
		flex-shrink: 0;
	}

	.card-title {
		font-family: var(--fonte-serif);
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--texto);
		line-height: 1.25;
		margin: 0;
	}

	.card-desc {
		font-size: 0.9rem;
		color: var(--texto-muted);
		line-height: 1.65;
		flex: 1;
		margin: 0;
	}

	.card-link {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--verde);
		text-decoration: none;
		transition: gap var(--dur) var(--ease), color var(--dur) var(--ease);
		margin-top: 0.25rem;
	}

	.card-link:hover { gap: 8px; color: var(--verde-claro); }

	.empty-msg {
		text-align: center;
		color: var(--texto-muted);
		padding: 4rem 0;
	}

	/* ── CTA ── */
	.cta-wrap { margin-bottom: 2rem; }

	.cta-box {
		position: relative;
		overflow: hidden;
		background: var(--texto);
		border-radius: var(--raio-xl);
		padding: clamp(3rem, 7vw, 5rem) clamp(2rem, 6vw, 4rem);
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25rem;
	}

	.cta-deco {
		position: absolute;
		top: -60px;
		right: -60px;
		width: 240px;
		height: 240px;
		background: radial-gradient(circle, rgba(45,122,95,0.25) 0%, transparent 70%);
		pointer-events: none;
	}

	.cta-title {
		font-family: var(--fonte-serif);
		font-size: clamp(1.6rem, 4vw, 2.4rem);
		font-weight: 700;
		color: var(--branco);
		letter-spacing: -0.02em;
		max-width: 520px;
	}

	.cta-sub {
		color: rgba(255,255,255,0.60);
		font-size: 1rem;
		max-width: 420px;
		line-height: 1.65;
	}

	.btn-lg { padding: 15px 36px; font-size: 1rem; }

	/* ── Utilitário ── */
	.br-md { display: none; }
	@media (min-width: 640px) { .br-md { display: inline; } }
</style>