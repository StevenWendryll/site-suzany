---
// Caminho: src/pages/index.astro

// 1. Importe o Layout
import LayoutBase from "../layouts/LayoutBase.astro";

// 2. Mantenha nossa busca de dados do Sanity (Exatamente como antes)
import { client } from "../lib/sanityClient";
type Servico = {
	titulo: string;
	resumo: string;
};
const query = `*[_type == "servico"]{ titulo, resumo }`;
const servicos = await client.fetch<Servico[]>(query);
---

<LayoutBase title="Início - Alívio da dor e recuperação">
	<section
		class="relative text-center rounded-lg overflow-hidden bg-cover bg-center"
		style="background-image: url('/images/hero-background.jpg');"
	>
		<div class="absolute inset-0 bg-black opacity-50"></div>

		<div class="relative z-10 p-8 md:p-16">
			<h1 class="text-4xl font-bold text-white mb-4">
				Alívio da Dor e Recuperação do Movimento
			</h1>
			<p class="text-lg text-gray-200 mb-8">
				Sua especialista em fisioterapia ortopédica e saúde da mulher.
			</p>

			<a
				href="/contato"
				class="bg-blue-700 text-white font-bold py-3 px-6 rounded-lg hover:bg-blue-800 w-full md:w-auto block md:inline-block"
			>
				Agende sua Avaliação (CTA Principal)
			</a>
		</div>
	</section>

	<section class="mt-16">
		<h2 class="text-3xl font-bold text-blue-800 text-center mb-8">Nossos Tratamentos</h2>

		{
			/* Usamos Tailwind Grid para criar as colunas 
        grid-cols-1: 1 coluna em celulares (mobile-first)
        md:grid-cols-3: 3 colunas em telas médias ou maiores (responsivo)
    */
		}
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			{
				servicos.map((servico) => (
					<div class="bg-white p-6 rounded-lg shadow-lg">
						<h3 class="text-xl font-bold text-blue-800 mb-2">
							{servico.titulo}
						</h3>
						<p class="text-gray-600">{servico.resumo}</p>
					</div>
				))
			}
		</div>
	</section>
</LayoutBase>
