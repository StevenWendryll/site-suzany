---
// Caminho: src/pages/sobre.astro
import LayoutBase from "../layouts/LayoutBase.astro";
---

<LayoutBase title="Sobre Mim">
    <div
        class="relative h-48 md:h-56 rounded-lg overflow-hidden bg-cover bg-center mb-8"
        style={`background-image: url('/public/images/sobre-background.jpg');`}
    >
        <div class="absolute inset-0 bg-black opacity-40"></div>

        <div class="relative z-10 flex items-center justify-center h-full">
            <h1 class="text-4xl font-bold text-white">Sobre Mim</h1>
        </div>
    </div>

    <section class="bg-white p-8 md:p-12 rounded-lg shadow-md">
        <div class="flex flex-col md:flex-row gap-8 md:gap-12 md:items-start">
            <div class="w-full md:w-1/3">
                <img
                    src='/public/images/suzany_site.png'
                    alt="Foto da Fisioterapeuta"
                    class="rounded-lg shadow-lg w-full"
                />
            </div>

            <div class="w-full md:w-2/3">
                <h2 class="text-3xl font-semibold text-blue-800 mb-4">
                    Minha Filosofia
                </h2>

                <p class="text-gray-700 text-lg mb-4 leading-relaxed">
                    Acredito em uma abordagem humanizada e individualizada,
                    focando não apenas na lesão, mas no bem-estar completo do
                    paciente. Meu objetivo é restaurar seu movimento e sua
                    qualidade de vida.
                </p>

                <h3 class="text-2xl font-semibold text-blue-800 mt-8 mb-4">
                    Formação e Credenciais
                </h3>

                <ul
                    class="list-disc list-inside text-gray-700 text-lg space-y-2"
                >
                    <li>Pós-graduação em Fisioterapia Ortopédica</li>
                    <li>Especialização em Saúde da Mulher</li>
                    <li>Formação em Pilates Clínico</li>
                    <li>CREFITO: 123456-F</li>
                </ul>
            </div>
        </div>
    </section>
</LayoutBase>
