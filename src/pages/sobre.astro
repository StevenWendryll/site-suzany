---
// Caminho: src/pages/sobre.astro
import LayoutBase from "../layouts/LayoutBase.astro";
import suzanyPhoto from '../assets/suzany_site.png';
---

<LayoutBase title="Sobre Mim">

	<!-- Conteúdo -->
	<section class="sobre-section" aria-label="Sobre a fisioterapeuta">
		<div class="sobre-foto">
			<div class="foto-wrap">
				<img
					src={suzanyPhoto.src}
					alt="Dra. Suzany Figueredo Lorencini – Fisioterapeuta"
					class="foto"
					loading="lazy"
				/>
				<div class="foto-badge">
					<strong>CREFITO</strong>
					<span>449069-F</span>
				</div>
			</div>
		</div>

		<div class="sobre-texto">
			<span class="eyebrow">Fisioterapeuta</span>
			<h2 class="sobre-titulo">Minha Filosofia de Cuidado</h2>
			<p class="sobre-p">
				Acredito em uma abordagem humanizada e individualizada, focando não apenas na lesão, mas
				no bem-estar completo do paciente. Cada pessoa é única e merece um plano terapêutico
				construído especialmente para ela.
			</p>
			<p class="sobre-p">
				Meu objetivo é restaurar seu movimento, aliviar a dor e devolver a qualidade de vida que
				você merece — com técnica, cuidado e dedicação em cada sessão.
			</p>

			<div class="credenciais">
				<h3 class="cred-titulo">Formação e Credenciais</h3>
				<ul class="cred-lista">
					<li>
						<div class="cred-icon" aria-hidden="true">🎓</div>
						<span>Pós-graduação em Neuropediatria</span>
					</li>
					<li>
						<div class="cred-icon" aria-hidden="true">🏅</div>
						<span>Formação em Pilates Clínico</span>
					</li>
					<li>
						<div class="cred-icon" aria-hidden="true">✅</div>
						<span>Registrada no CREFITO – 449069-F</span>
					</li>
				</ul>
			</div>

			<a href="/contato" class="btn-primary sobre-cta">Agendar uma avaliação</a>
		</div>
	</section>
</LayoutBase>

<style>
	.sobre-section {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		background: var(--branco);
		border-radius: var(--raio-xl);
		padding: clamp(2rem, 5vw, 3.5rem);
		box-shadow: var(--sombra-sm);
		border: 1px solid var(--borda);
	}

	@media (min-width: 768px) {
		.sobre-section { grid-template-columns: 5fr 7fr; gap: 4rem; align-items: start; }
	}

	/* Foto */
	.foto-wrap {
		position: relative;
		display: inline-block;
		width: 100%;
	}

	.foto {
		width: 100%;
		border-radius: var(--raio-lg);
		object-fit: cover;
		aspect-ratio: 3/4;
		box-shadow: var(--sombra-md);
	}

	.foto-badge {
		position: absolute;
		bottom: 1rem;
		left: 1rem;
		background: var(--branco);
		border-radius: 10px;
		padding: 8px 14px;
		box-shadow: var(--sombra-sm);
		display: flex;
		flex-direction: column;
		line-height: 1.2;
	}

	.foto-badge strong {
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--verde);
	}

	.foto-badge span {
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--texto);
	}

	/* Texto */
	.eyebrow {
		display: inline-block;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--verde);
		margin-bottom: 0.75rem;
	}

	.sobre-titulo {
		font-family: var(--fonte-serif);
		font-size: clamp(1.6rem, 3.5vw, 2.2rem);
		font-weight: 700;
		color: var(--texto);
		letter-spacing: -0.02em;
		margin-bottom: 1.25rem;
		line-height: 1.15;
	}

	.sobre-p {
		font-size: 1rem;
		color: var(--texto-muted);
		line-height: 1.75;
		margin-bottom: 1rem;
	}

	/* Credenciais */
	.credenciais {
		margin: 2rem 0;
		padding: 1.75rem;
		background: var(--verde-suave);
		border-radius: var(--raio-lg);
		border: 1px solid var(--verde-mid);
	}

	.cred-titulo {
		font-family: var(--fonte-serif);
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--texto);
		margin-bottom: 1rem;
	}

	.cred-lista {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.cred-lista li {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.95rem;
		color: var(--texto);
		font-weight: 500;
	}

	.cred-icon {
		font-size: 1.1rem;
		flex-shrink: 0;
	}

	.sobre-cta { margin-top: 0.5rem; }
</style>